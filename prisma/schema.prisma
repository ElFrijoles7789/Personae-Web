// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Character {
  id                  String   @id @default(cuid())
  name                String
  description         String   // brief user-provided description used for AI character creation
  physicalDescription String?  // physical traits
  psychologicalDescription String? // psychological traits
  scenario            String?  // initial scenario / setting
  greeting            String?  // opening message from character
  avatar              String?  // URL or data path to avatar image
  avatarSource        String?  // optional: source URL if AI-generated
  creatorName         String?  // display name of creator
  published           Boolean  @default(false)
  tags                String?  // comma separated tags
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  chats               Chat[]
}

model Chat {
  id          String    @id @default(cuid())
  title       String
  characterId String
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  messages    Message[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  role      String   // "user" | "assistant" | "system"
  content   String
  createdAt DateTime @default(now())
}
